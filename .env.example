# ============================================================
#  SentinelAI — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── Application ─────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── PostgreSQL ───────────────────────────────────────────────
# In Docker: use service name "postgres" as host
# Locally:   use "localhost"
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinelai_db
POSTGRES_USER=sentinelai_user
POSTGRES_PASSWORD=sentinelai_secure_pass_change_me

# ── Redis ────────────────────────────────────────────────────
# In Docker: use service name "redis" as host
# Locally:   use "localhost"
REDIS_HOST=redis
REDIS_PORT=6379

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:5173"]

# ── JWT (RS256) ──────────────────────────────────────────────
# Generated in Phase 2 — leave blank for now
# To generate:
#   openssl genrsa -out private_key.pem 2048
#   openssl rsa -in private_key.pem -pubout -out public_key.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
